NODE_ENV=development

DISCORD_TOKEN=replace-me
DISCORD_CLIENT_ID=replace-me
DISCORD_GUILD_ID=replace-me
BOT_OWNER_ID=replace-me

AI_BASE_URL=https://api.xiaomimimo.com/v1
AI_API_KEY=replace-me
AI_MODEL=mimo-v2.5-pro
AI_FALLBACK_MODEL=
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=1000
AI_CONTEXT_WINDOW_TOKENS=
AI_STREAMING_ENABLED=true
AI_STREAM_TIMEOUT_MS=60000
AI_PROVIDER=auto

# MiMo Web Search is server-managed. Enable the plugin in the MiMo Console first.
# Search can increase latency and provider-side cost.
AI_WEB_SEARCH_ENABLED=true
AI_WEB_SEARCH_MODE=auto
AI_WEB_SEARCH_MAX_KEYWORD=5
AI_WEB_SEARCH_LIMIT=3
AI_THINKING_TYPE=disabled
AI_SHOW_SEARCH_ANNOTATIONS=false
AI_NOTIFY_SEARCH_DOWNGRADE=true

# App-side Web Search through Tavily. Keep AI_WEB_SEARCH_ENABLED=false when this is enabled.
# Search can increase latency and may consume Tavily quota.
SEARCH_ENABLED=false
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=
SEARCH_RESULT_LIMIT=2
SEARCH_CACHE_TTL_MS=300000
SEARCH_RATE_LIMIT_MAX=10
SEARCH_RATE_LIMIT_WINDOW_MS=60000
SEARCH_DAILY_LIMIT=100
SEARCH_DAILY_WARNING_RATIO=0.8
SEARCH_LLM_INTENT_ENABLED=false
SEARCH_SHOW_SKIP_REASON=false
SEARCH_PROGRESS_NOTICE=true

# Storage. Use sqlite for long-running deployments; memory is convenient for development.
STORAGE_DRIVER=memory
SQLITE_DB_PATH=data/echomate.sqlite
SQLITE_MAX_DB_SIZE_MB=512
USAGE_RETENTION_DAYS=90
USAGE_OWNER_DETAIL_ENABLED=false
CONVERSATION_CLEANUP_ENABLED=true
CONVERSATION_CLEANUP_INTERVAL_MS=3600000
MAX_CONVERSATIONS_PER_USER=1000
GRACEFUL_SHUTDOWN_TIMEOUT_MS=30000

# Optional channel controls. Use comma-separated Discord channel/thread IDs.
CHANNEL_ALLOWLIST=
CHANNEL_BLOCKLIST=
MESSAGE_REFERENCE_ENABLED=true
FEEDBACK_REACTIONS_ENABLED=false

ENABLE_MENTION_TRIGGER=true
MENTION_DAILY_LIMIT=100
MAX_CONTEXT_MESSAGES=30
CONTEXT_TTL_HOURS=12
MAX_USER_PROMPT_CHARS=4000

USER_RATE_LIMIT_MAX=5
USER_RATE_LIMIT_WINDOW_MS=60000
CHANNEL_RATE_LIMIT_MAX=20
CHANNEL_RATE_LIMIT_WINDOW_MS=60000

LOG_LEVEL=debug
LOG_DESTINATION=
HEALTH_CHECK_PORT=0

# Optional. Useful when discord.com is unreachable from your network.
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
