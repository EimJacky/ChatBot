{
  "name": "discord-ai-chat-bot",
  "version": "1.0.0",
  "description": "Industrial-grade local MVP Discord AI group chat bot.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "register": "tsx src/register-commands.ts",
    "doctor": "tsx src/doctor.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "bottleneck": "^2.19.5",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "gpt-tokenizer": "^3.4.0",
    "lru-cache": "^11.5.0",
    "openai": "^6.39.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "undici": "^6.24.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
